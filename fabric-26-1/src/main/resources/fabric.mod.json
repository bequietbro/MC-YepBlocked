{
    "schemaVersion": 1,
    "id": "${mod_id}",
    "version": "${version}",
    "name": "${mod_name}",
    "description": "${mod_description}",
    "authors": [ "${mod_authors}" ],
    "license": "${mod_license}",
    "icon": "icon.png",
    "environment": "*",
    "entrypoints": {
        "main": [
            {
                "adapter": "kotlin",
                "value": "dev.beqi.yepblocked.Yepblocked"
            }
        ]
    },
    "depends": {
        "fabricloader": ">=${loader_version}",
        "fabric-api": "*",
        "fabric-language-kotlin": ">=${flk_version}",
        "minecraft": ">=26.1",
        "java": ">=25"
    }
}
